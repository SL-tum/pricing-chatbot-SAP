# Copy this file to .env for ad-hoc local scripts only.
# CAP service bindings should preferably be created with `cds bind`,
# which writes credentials to .cdsrc-private.json.

# Optional direct OAuth fallback, if you add code that explicitly needs it:
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Optional AI Core / destination values. Prefer SAP BTP Destination service.
GENERATIVE_AI_HUB_URL=
GENERATIVE_AI_HUB_CLIENT_ID=
GENERATIVE_AI_HUB_CLIENT_SECRET=
